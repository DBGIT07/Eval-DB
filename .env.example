DATABASE_URL=postgresql+psycopg2://evaldb:evaldb@localhost:5432/evaldb
JWT_SECRET_KEY=change-this-before-running
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional API keys for evaluation providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Evaluation defaults
EVAL_DEFAULT_PROVIDER=mock
EVAL_DEFAULT_MODEL=mock
EVAL_FALLBACK_PROVIDER=mock
EVAL_MAX_CONCURRENT_JOBS=1
EVAL_RESPECT_RETRY_AFTER=true
EVAL_ASYNC_MIN_SAMPLES=25

# UI defaults
UI_DEFAULT_PROVIDER=mock
UI_DEFAULT_MODEL=mock
UI_SHOW_PROVIDER_SELECTOR=true

# Judge tuning
EVAL_JUDGE_MAX_PROMPT_CHARS=4000
EVAL_JUDGE_MAX_RESPONSE_CHARS=4000
EVAL_JUDGE_MAX_CONTEXT_ITEMS=12
EVAL_JUDGE_MAX_CONTEXT_ITEM_CHARS=2000
EVAL_JUDGE_MAX_CONTEXT_CHARS=12000
GROQ_JUDGE_MAX_ATTEMPTS=5
GROQ_JUDGE_RETRY_BASE_DELAY_SECONDS=2
GROQ_JUDGE_RETRY_BACKOFF_MULTIPLIER=2
GROQ_JUDGE_RETRY_MAX_DELAY_SECONDS=60
GROQ_JUDGE_TIMEOUT_SECONDS=30
GROQ_JUDGE_SDK_MAX_RETRIES=3
